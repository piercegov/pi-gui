{
	"name": "pi-gui",
	"version": "0.1.0",
	"description": "Electrobun desktop app for managing Pi coding sessions",
	"type": "module",
	"workspaces": ["packages/*"],
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"electrobun dev --watch\"",
		"hmr": "vite --port 5173",
		"build": "vite build && electrobun build",
		"build:canary": "vite build && electrobun build --env=canary",
		"typecheck": "bunx tsc --noEmit"
	},
	"dependencies": {
		"@mariozechner/pi-coding-agent": "0.56.1",
		"@pi-gui/pi-review-extension": "workspace:*",
		"@radix-ui/react-dialog": "latest",
		"@radix-ui/react-dropdown-menu": "latest",
		"@radix-ui/react-popover": "latest",
		"@radix-ui/react-scroll-area": "latest",
		"@radix-ui/react-select": "latest",
		"@radix-ui/react-separator": "latest",
		"@radix-ui/react-switch": "latest",
		"@radix-ui/react-tabs": "latest",
		"@radix-ui/react-tooltip": "latest",
		"@tanstack/react-virtual": "^3.13.20",
		"clsx": "^2.1.1",
		"electrobun": "1.14.4",
		"lucide-react": "^0.577.0",
		"react": "^18.3.1",
		"react-diff-view": "^3.3.2",
		"react-dom": "^18.3.1",
		"react-markdown": "^10.1.0",
		"refractor": "^5.0.0",
		"remark-gfm": "^4.0.1",
		"shiki": "^4.0.1",
		"tailwind-merge": "^3.5.0",
		"xterm": "^5.3.0",
		"xterm-addon-fit": "^0.8.0",
		"zod": "^4.3.6",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/node": "^24.3.0",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.9.2",
		"vite": "^6.0.3"
	}
}
